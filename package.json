{
  "name": "cashu-l402",
  "version": "0.1.0",
  "description": "Integration of Cashu ecash protocol with L402 (HTTP 402 Payment Required) for privacy-preserving API monetization",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "node node_modules/jest/bin/jest.js",
    "test:watch": "node node_modules/jest/bin/jest.js --watch",
    "lint": "eslint src/**/*.ts",
    "clean": "rimraf dist"
  },
  "keywords": ["cashu", "l402", "lightning", "ecash", "bitcoin", "micropayments"],
  "license": "MIT",
  "dependencies": {
    "@cashu/cashu-ts": "^2.0.0",
    "express": "^4.18.2",
    "@types/express": "^4.17.21"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.11.5",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.11",
    "ts-jest": "^29.1.2",
    "rimraf": "^5.0.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/src/__tests__/**/*.test.ts"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
