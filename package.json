{
  "name": "@te-btc/cashu-l402",
  "version": "0.1.0",
  "description": "Cashu ecash ↔ L402 settlement bridge — atomic ecash-to-macaroon exchange",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "tsx examples/demo.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@cashu/cashu-ts": "^2.5.0",
    "@noble/curves": "^1.8.1",
    "@noble/hashes": "^1.7.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "keywords": [
    "cashu",
    "l402",
    "ecash",
    "lightning",
    "macaroon",
    "paywall",
    "bitcoin",
    "micropayments"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Traviseric/cashu-l402.git"
  }
}
